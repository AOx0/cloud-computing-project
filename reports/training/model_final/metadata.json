{
  "model_type": "LinearSVC + CalibratedClassifierCV (sigmoid, cv=3)",
  "features": "TF-IDF char_wb (2,5) + nomic-embed-text-v1.5 (classification, 768d)",
  "tfidf_config": {
    "analyzer": "char_wb",
    "ngram_range": [
      2,
      5
    ],
    "sublinear_tf": true,
    "min_df": 3,
    "max_df": 0.7
  },
  "embedding_config": {
    "model": "nomic-ai/nomic-embed-text-v1.5",
    "task_type": "classification",
    "dimensions": 768,
    "api": "https://api.synthetic.new/openai/v1/embeddings"
  },
  "linear_svc_params": {
    "class_weight": "balanced",
    "max_iter": 5000,
    "C": 0.1
  },
  "label_cols": [
    "toxic",
    "severe_toxic",
    "obscene",
    "threat",
    "insult",
    "identity_hate"
  ],
  "f2_optimal_thresholds": {
    "toxic": 0.15,
    "severe_toxic": 0.1,
    "obscene": 0.1,
    "threat": 0.15,
    "insult": 0.15,
    "identity_hate": 0.1
  },
  "metrics": {
    "auc_macro": 0.9903,
    "f1_macro": 0.6388,
    "f2_macro": 0.7323
  }
}